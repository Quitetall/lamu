# Environment for the lamu-serve systemd unit.
# Copy to ~/.config/lamu/lamu-serve.env and edit. Every line is optional —
# unset variables fall back to the in-code defaults shown here.
#
# NOTE: cloud API keys do NOT go here. The binary loads them itself from
# ~/.config/lamu/api-keys.env before any subcommand runs.

# ── Binding & auth ───────────────────────────────────────────────────────
# Loopback by default (ADR 0005). Off-loopback REQUIRES auth: set a real
# token below (or provision ~/.config/lamu/api-token) before flipping the
# bind host, or startup will refuse (ADR 0012/0018). This is the serve
# bearer token — NOT a cloud provider key (those live in api-keys.env).
#LAMU_BIND_HOST=127.0.0.1
#LAMU_API_TOKEN=<required-for-off-loopback>

# ── Logging ──────────────────────────────────────────────────────────────
# journald captures stdout/stderr; tune verbosity here.
#RUST_LOG=info

# ── Reconcile / scheduling ───────────────────────────────────────────────
# Seconds between scheduler↔process ground-truth reconcile sweeps.
#LAMU_RECONCILE_SECS=30
# Per-model backend concurrency (default 1 = serial per model, ADR 0024).
#LAMU_QUEUE_CONCURRENCY=1
#LAMU_QUEUE_STRATEGY=fifo
# Opt-in HTTP auto-evict (default off — ADR 0006).
#LAMU_HTTP_AUTOEVICT=0

# ── GPU selection (multi-GPU rigs, ADR 0017) ─────────────────────────────
#LAMU_GPU_INDEX=0
#LAMU_GPU_INDICES=

# ── Grounding (optional, best-effort) ────────────────────────────────────
# Self-hosted SearXNG for LAMU_AUTO_GROUND + jart web_search. Serve runs
# fine without it; lookups just fail soft.
#SEARXNG_URL=http://127.0.0.1:8888
#LAMU_AUTO_GROUND=0

# ── Backend paths ────────────────────────────────────────────────────────
#LAMU_LLAMACPP_DIR=
# Explicit path to the BeeLlama llama-server build (DFlash/turbo KV fork);
# auto-discovered when unset.
#LAMU_BEE_BIN=
# KV cache type: q8_0 q4_0 q4_1 q5_0 q5_1 f16 bf16 f32 turbo2 turbo3
# turbo3_tcq turbo4 (turbo* need the BeeLlama build).
#LAMU_KV=

# ── Context management (ADR 0021) ────────────────────────────────────────
#LAMU_DEFAULT_CTX=
#LAMU_CTX_NEAR_FULL=0.85

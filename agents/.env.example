# Bifrost gateway (all model calls route through here)
BIFROST_URL=http://localhost:8080/v1
BIFROST_KEY=sk-local

# Swarm model assignments (provider/model format — Bifrost routes by prefix)
PLANNER_MODEL=anthropic/claude-opus-4-7
WORKER_MODEL=dflash/luce-dflash
CRITIC_MODEL=anthropic/claude-sonnet-4-6

# Langfuse tracing (optional)
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=http://localhost:3000

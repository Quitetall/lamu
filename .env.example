# Root env — API keys for cloud providers through Bifrost.
# Copy to .env and fill in your keys. Bifrost reads these from config.json
# (edit deps/bifrost/config.json directly), but agents also need them for
# direct SDK calls when Bifrost is bypassed.

ANTHROPIC_API_KEY=sk-ant-...
OPENAI_API_KEY=sk-...

# Local gateway
BIFROST_URL=http://localhost:8080/v1
BIFROST_KEY=sk-local
